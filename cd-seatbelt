#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
# cd-seatbelt — launch Claude Desktop inside a macOS seatbelt sandbox
# ============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROFILE="${SCRIPT_DIR}/profile.sb"
APP="/Applications/Claude.app/Contents/MacOS/Claude"
SANDBOX_DIR="$HOME/Claude-Sandbox"

if [[ ! -f "$PROFILE" ]]; then
  echo "Error: profile.sb not found at $PROFILE" >&2
  exit 1
fi

if [[ ! -f "$APP" ]]; then
  echo "Error: Claude Desktop not found at $APP" >&2
  echo "Install it from https://claude.ai/download" >&2
  exit 1
fi

mkdir -p "$SANDBOX_DIR"

echo "Launching Claude Desktop (sandboxed — ~/Claude-Sandbox only)"
echo "  Workspace: $SANDBOX_DIR"
echo ""

exec sandbox-exec -f "$PROFILE" -D "HOME=$HOME" "$APP" --no-sandbox
