#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
# Self-contained launcher — launches Claude Desktop inside a macOS sandbox
# ============================================================================

APP_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PROFILE="${APP_DIR}/Resources/profile.sb"
CLAUDE_APP="/Applications/Claude.app/Contents/MacOS/Claude"
SANDBOX_DIR="$HOME/Claude-Sandbox"

# ---- check profile exists ----
if [[ ! -f "$PROFILE" ]]; then
  osascript -e 'display alert "Claude Desktop Sandboxed" message "profile.sb not found inside the app bundle." as critical'
  exit 1
fi

# ---- check Claude Desktop is installed ----
if [[ ! -f "$CLAUDE_APP" ]]; then
  osascript -e 'display alert "Claude Desktop Sandboxed" message "Claude Desktop not found at /Applications/Claude.app. Install it from https://claude.ai/download" as critical'
  exit 1
fi

# ---- create sandbox workspace ----
mkdir -p "$SANDBOX_DIR"

# ---- launch sandboxed ----
exec sandbox-exec -f "$PROFILE" -D "HOME=$HOME" "$CLAUDE_APP" --no-sandbox
